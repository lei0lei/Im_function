{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-DOpenCV_DIR=C:/tools/opencv/build",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Release"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "${workspaceFolder}/build/Release/Im_function.exe",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\tools\\opencv\\build\\x64\\vc16\\bin;${env:PATH}"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Run",
            "dependsOn": [
                "Build",
                "Run"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure (Tracy)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build_tracy",
                "-DOpenCV_DIR=C:/tools/opencv/build",
                "-DIM_FUNCTION_ENABLE_TRACY=ON",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build (Tracy)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build_tracy",
                "--config", "Release"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run (Tracy)",
            "type": "shell",
            "command": "${workspaceFolder}/build_tracy/Release/Im_function.exe",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\tools\\opencv\\build\\x64\\vc16\\bin;${env:PATH}"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Run (Tracy)",
            "dependsOn": [
                "CMake: Configure (Tracy)",
                "Build (Tracy)",
                "Run (Tracy)"
            ],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        }
    ]
}
